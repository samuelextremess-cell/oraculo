# ── Oráculo — variáveis de ambiente ──
# Copie este arquivo para .env e preencha com seus valores.
# ⚠️  NUNCA comite o .env! Ele já está no .gitignore.

# Hugging Face API Token — acesso a modelos gratuitos (DeepSeek-V3, Qwen, etc.)
HF_TOKEN=seu_hf_token_aqui

# DeepSeek API Token — acesso direto à API oficial da DeepSeek (mais rápida)
DS_TOKEN=seu_deepseek_token_aqui

# GitHub Personal Access Token — push de arquivos/código gerado pela IA
GITHUB_TOKEN=seu_github_token_aqui

# Repositório GitHub (formato: usuario/nome-do-repo)
GITHUB_REPO=seu_usuario/nome_repo

# Branch principal do repositório
GITHUB_BRANCH=main
