# Hugging Face API Token — acesso a modelos do Hugging Face
HF_TOKEN=seu_hf_token_aqui

# DeepSeek API Token — acesso à API DeepSeek AI
DS_TOKEN=seu_deepseek_token_aqui

# GitHub Personal Access Token — autenticação com GitHub (push, repo, etc.)
GITHUB_TOKEN=seu_github_token_aqui

# Repositório GitHub
GITHUB_REPO=seu_usuario/nome_repo

# Branch principal
GITHUB_BRANCH=main
